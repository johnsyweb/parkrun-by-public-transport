{
  "name": "parkrun-by-public-transport",
  "version": "1.0.0",
  "description": "Find parkrun events near public transport stops",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "aube run generate:icons && tsc && aube run generate:sitemap && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:lighthouse": "aube run build && tsx scripts/run-lighthouse.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write '**/*.{ts,tsx,json,css,html,md,yml}'",
    "format:check": "prettier --check '**/*.{ts,tsx,json,css,html,md}'",
    "check": "aube run typecheck && aube run validate:public-data && aube test && aube run test:lighthouse && aube run lint && aube run format:check",
    "validate:public-data": "tsx scripts/validate-public-data.ts",
    "generate:sitemap": "tsx scripts/generate-sitemap.ts",
    "generate:icons": "tsx scripts/generate-icons.ts",
    "generate:screenshot": "tsx scripts/generate-screenshot.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "leaflet": "^1.9.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/leaflet": "^1.9.21",
    "eslint": "^10.3.0",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "lighthouse": "^13.3.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^7.3.3",
    "vitest": "4.1.7"
  }
}
